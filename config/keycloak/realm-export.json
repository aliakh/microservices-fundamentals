{
  "realm": "microservices-fundamentals-realm",
  "enabled": true,
  "displayName": "Microservices Rundamentals realm",
  "roles": {
    "realm": [
      {
        "name": "admin"
      },
      {
        "name": "user"
      }
    ]
  },
  "clients": [
    {
      "clientId": "storage-service",
      "enabled": true,
      "protocol": "openid-connect",
      "clientAuthenticatorType": "client-secret",
      "secret": "storage-service-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "publicClient": false,
      "directAccessGrantsEnabled": true,
      "bearerOnly": false,
      "attributes": {},
      "defaultClientScopes": [
        "roles",
        "profile",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles"
          }
        }
      ]
    },
    {
      "clientId": "resource-service",
      "enabled": true,
      "protocol": "openid-connect",
      "clientAuthenticatorType": "client-secret",
      "secret": "resource-service-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "publicClient": false,
      "directAccessGrantsEnabled": false,
      "bearerOnly": false,
      "attributes": {},
      "defaultClientScopes": [
        "roles",
        "profile",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin_user",
      "enabled": true,
      "emailVerified": true,
      "firstName": "System",
      "lastName": "Administrator",
      "email": "admin@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ]
    },
    {
      "username": "normal_user",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Normal",
      "lastName": "User",
      "email": "user@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "user",
          "temporary": false
        }
      ],
      "realmRoles": [
        "user"
      ]
    },
    {
      "username": "service-account-resource-service",
      "enabled": true,
      "serviceAccountClientId": "resource-service",
      "emailVerified": true,
      "firstName": "service account",
      "lastName": "resource service",
      "credentials": [],
      "realmRoles": [
        "admin"
      ],
      "clientRoles": {},
      "groups": []
    }
  ]
}
